{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "changelog-sections": [
    {
      "type": "feat",
      "section": "Features",
      "hidden": false
    },
    {
      "type": "fix",
      "section": "Bug Fixes",
      "hidden": false
    },
    {
      "type": "docs",
      "section": "Documentation",
      "hidden": false
    },
    {
      "type": "style",
      "section": "Styles",
      "hidden": true
    },
    {
      "type": "refactor",
      "section": "Refactoring",
      "hidden": true
    },
    {
      "type": "perf",
      "section": "Performance",
      "hidden": true
    },
    {
      "type": "test",
      "section": "Tests",
      "hidden": true
    },
    {
      "type": "chore",
      "section": "Miscellaneous",
      "hidden": true
    }
  ],
  "packages": {
    ".": {
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        "packages/fr-config-common/package.json",
        "packages/fr-config-delete/package.json",
        "packages/fr-config-promote/package.json",
        "packages/fr-config-pull/package.json",
        "packages/fr-config-push/package.json"
      ]
    }
  }
}
